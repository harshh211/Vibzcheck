rules_version = '2';

// Vibzcheck Firestore security rules.
// All access is scoped via request.auth.uid. Anonymous access is denied everywhere.
service cloud.firestore {
  match /databases/{database}/documents {

    // ---- Helpers ----
    function isSignedIn() {
      return request.auth != null;
    }

    function isUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isSessionMember(sessionId) {
      return isSignedIn()
        && request.auth.uid in get(/databases/$(database)/documents/sessions/$(sessionId)).data.memberIds;
    }

    // ---- Users ----
    // A user can read any profile (needed to render names/avatars in a shared session),
    // but can only create/update their own profile document.
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isUser(userId);
      allow delete: if false;
    }

    // ---- Sessions ----
    match /sessions/{sessionId} {
      // Any signed-in user can read sessions (needed to look up by joinCode).
      // Only members can see the full member list / active state.
      allow read: if isSignedIn();

      // Any signed-in user can create a session IF they set themselves as host.
      allow create: if isSignedIn()
        && request.resource.data.hostId == request.auth.uid
        && request.auth.uid in request.resource.data.memberIds;

      // Update rules:
      //   - host can update anything
      //   - members can only update memberIds (to join/leave)
      allow update: if isSignedIn() && (
        resource.data.hostId == request.auth.uid
        || (request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['memberIds']))
      );

      allow delete: if resource.data.hostId == request.auth.uid;

      // ---- Tracks subcollection ----
      match /tracks/{trackId} {
        allow read: if isSessionMember(sessionId);

        // Adding a track: must be a member, must mark yourself as addedBy.
        allow create: if isSessionMember(sessionId)
          && request.resource.data.addedBy == request.auth.uid
          && request.resource.data.voteScore == 0;

        // Updates: restricted to vote-related fields (members) or full (host/adder).
        // Non-host/non-adder can only change: voteScore, upvoters, downvoters, moodTags.
        allow update: if isSessionMember(sessionId) && (
          resource.data.addedBy == request.auth.uid
          || get(/databases/$(database)/documents/sessions/$(sessionId)).data.hostId == request.auth.uid
          || request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['voteScore', 'upvoters', 'downvoters', 'moodTags'])
        );

        allow delete: if isSessionMember(sessionId) && (
          resource.data.addedBy == request.auth.uid
          || get(/databases/$(database)/documents/sessions/$(sessionId)).data.hostId == request.auth.uid
        );
      }

      // ---- Messages subcollection ----
      match /messages/{messageId} {
        allow read: if isSessionMember(sessionId);
        allow create: if isSessionMember(sessionId)
          && request.resource.data.senderId == request.auth.uid;
        allow update, delete: if false;   // immutable once sent
      }
    }
  }
}
